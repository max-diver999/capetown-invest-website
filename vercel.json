{
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.capetown-invest.com" }],
      "destination": "https://capetown-invest.com/:path*",
      "permanent": true
    },
    {
      "source": "/guides/uk-buyers-cape-town-property/",
      "destination": "/segments/uk-buyers-cape-town-property/",
      "permanent": true
    },
    {
      "source": "/guides/german-buyers-cape-town-property/",
      "destination": "/segments/german-buyers-cape-town-property/",
      "permanent": true
    },
    {
      "source": "/guides/us-buyers-cape-town-property/",
      "destination": "/segments/us-buyers-cape-town-property/",
      "permanent": true
    },
    {
      "source": "/guides/western-cape-vs-gauteng-property-investment/",
      "destination": "/compare/western-cape-vs-gauteng-property-investment/",
      "permanent": true
    },
    {
      "source": "/guides/nhbc-warranty-south-africa-new-build/",
      "destination": "/guides/nhbrc-warranty-south-africa-new-build/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ]
}
