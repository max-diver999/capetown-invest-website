---
import { SITE } from '../data/site';

interface Props {
  title?: string;
  subtitle?: string;
  context?: string;
}

const {
  title = 'Get your Cape Town property shortlist',
  subtitle = 'Share your budget and target area — we respond within one business day.',
  context = '',
} = Astro.props;
---
<section class="surface-card p-8 md:p-10" id="lead-form">
  <span class="badge-pill mb-3">Free · Independent advisory</span>
  <h2 class="text-2xl mb-1 text-[var(--color-ink)]">{title}</h2>
  <p class="text-[var(--color-muted)] mb-5 text-sm">{subtitle}</p>

  <form class="grid gap-4 ig-lead-form" id="ig-lead-form" data-context={context} novalidate>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-medium mb-1" for="lf-name">Your name *</label>
        <input type="text" id="lf-name" name="name" required placeholder="John Smith" autocomplete="name" />
      </div>
      <div>
        <label class="block text-xs font-medium mb-1" for="lf-phone">WhatsApp / Phone *</label>
        <input type="tel" id="lf-phone" name="phone" required placeholder="+44 7700 900123" autocomplete="tel" />
      </div>
    </div>
    <div>
      <label class="block text-xs font-medium mb-1" for="lf-email">Email</label>
      <input type="email" id="lf-email" name="email" placeholder="john@example.com" autocomplete="email" />
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-medium mb-1" for="lf-market">Target area</label>
        <select id="lf-market" name="market">
          <option value="">— Select —</option>
          <option value="atlantic-seaboard">Atlantic Seaboard (Sea Point, Camps Bay, Clifton)</option>
          <option value="city-bowl">City Bowl / Waterfront</option>
          <option value="southern-suburbs">Southern Suburbs</option>
          <option value="century-city">Century City / Blouberg</option>
          <option value="winelands">Winelands / Stellenbosch</option>
          <option value="not-sure">Not sure yet</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium mb-1" for="lf-budget">Budget (ZAR, all-in)</label>
        <select id="lf-budget" name="budget">
          <option value="">— Select —</option>
          <option value="under-3m">Under R3M</option>
          <option value="3-5m">R3M – R5M</option>
          <option value="5-10m">R5M – R10M</option>
          <option value="10-20m">R10M – R20M</option>
          <option value="20m+">R20M+</option>
        </select>
      </div>
    </div>
    <div>
      <label class="block text-xs font-medium mb-1" for="lf-goal">Your goal</label>
      <select id="lf-goal" name="goal">
        <option value="">— Select —</option>
        <option value="investment">Rental yield / investment</option>
        <option value="own-stay">Own stay / relocation / semigration</option>
        <option value="holiday-home">Holiday home</option>
        <option value="off-plan">New development / off-plan</option>
        <option value="explore">Just researching</option>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium mb-1" for="lf-message">Message (optional)</label>
      <textarea id="lf-message" name="message" rows="3" placeholder="E.g. 2-bed Sea Point apartment, foreign buyer, budget R4M all-in including transfer duty…"></textarea>
    </div>
    <label class="flex items-start gap-2 text-xs text-[var(--color-muted)] cursor-pointer">
      <input type="checkbox" name="consent" required class="mt-1 w-4 h-4" />
      <span>I agree to be contacted about my enquiry. See our <a href="/privacy-policy/">Privacy Policy</a>.</span>
    </label>
    <button type="submit" class="btn-primary w-full py-3">Request shortlist →</button>
    <p id="lf-success" class="hidden text-green-700 text-sm font-medium text-center">Thank you — redirecting…</p>
    <p id="lf-error" class="hidden text-red-700 text-sm font-medium text-center">Something went wrong. Please try again or email {SITE.email}.</p>
  </form>
</section>

<script>
  const form = document.getElementById('ig-lead-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const payload = {
        name: String(fd.get('name') || ''),
        contact: String(fd.get('phone') || fd.get('email') || ''),
        email: String(fd.get('email') || ''),
        phone: String(fd.get('phone') || ''),
        market: String(fd.get('market') || ''),
        budget: String(fd.get('budget') || ''),
        goal: String(fd.get('goal') || ''),
        message: String(fd.get('message') || ''),
        source: form.dataset.context || 'lead-form',
      };
      const successEl = document.getElementById('lf-success');
      const errorEl = document.getElementById('lf-error');
      try {
        const res = await fetch('/api/lead/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.ok) {
          successEl?.classList.remove('hidden');
          errorEl?.classList.add('hidden');
          setTimeout(() => { window.location.href = '/thanks/'; }, 800);
        } else {
          errorEl?.classList.remove('hidden');
        }
      } catch {
        errorEl?.classList.remove('hidden');
      }
    });
  }
</script>
