---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/LeadForm.astro';
---
<BaseLayout
  title="Get Your Cape Town Property Shortlist"
  description="Tell us your budget and target area (Sea Point, City Bowl, Atlantic Seaboard, Winelands). Free independent shortlist within one business day."
>
  <section class="site-container py-12 md:py-16 max-w-2xl">
    <header class="mb-8">
      <h1 class="mb-3">Get your shortlist</h1>
      <p class="text-lg text-[var(--color-muted)]">
        Share budget, preferred suburb, and goal (yield, lifestyle, semigration). We match you with vetted resale and off-plan options — no spam, no developer pressure.
      </p>
    </header>
    <LeadForm
      title="Request your shortlist"
      subtitle="Licensed SA partner review · Atlantic Seaboard · City Bowl · Winelands"
      context="Get shortlist page"
    />
    <p class="text-xs text-[var(--color-muted)] mt-6">
      By submitting you agree to our <a href="/privacy-policy/">Privacy Policy</a>.
      Not financial, tax, or legal advice.
    </p>
  </section>
</BaseLayout>
