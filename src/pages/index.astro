---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../data/site';
import { HOMEPAGE_HERO_IMAGE } from '../data/featured';
import { getCardImageUrl } from '../lib/cardImage';

const [guides, projects, areas] = await Promise.all([
  getCollection('guides'),
  getCollection('projects'),
  getCollection('areas'),
]);

const publishedGuides = guides.filter((g) => !g.data.noindex);
const publishedProjects = projects.filter((p) => !p.data.noindex);
const publishedAreas = areas.filter((a) => !a.data.noindex);

const heroImage = getCardImageUrl(HOMEPAGE_HERO_IMAGE, 'hero');
---
<BaseLayout
  title="Cape Town Property Investment for Foreign Buyers — 2026"
  description="Independent Cape Town property research for foreign buyers: no surcharge, 50% bond, Atlantic Seaboard yields, project reviews. Free shortlist within one business day."
>
  <section class="border-b border-[var(--color-border-soft)] bg-[var(--color-surface)]">
    <div class="site-container py-14 md:py-20 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div>
        <span class="badge-pill mb-5">Independent · No developer pressure</span>
        <h1 class="text-3xl md:text-[2.35rem] mb-5 leading-tight">
          Cape Town property investment for foreign buyers
        </h1>
        <p class="text-base md:text-lg text-[var(--color-muted)] mb-6 max-w-xl">
          Atlantic Seaboard, City Bowl, Winelands — ownership rules, transfer costs, rental yields, and vetted project reviews. Licensed South African partner for transactions; we do not sell developer stock.
        </p>
        <ul class="text-sm text-[var(--color-muted)] space-y-2 mb-8 max-w-xl">
          <li>✓ No foreign buyer surcharge (vs UK 2% / Singapore 60%)</li>
          <li>✓ Non-residents: up to 50% local bond, no visa required to buy</li>
          <li>✓ Free shortlist — reply within one business day</li>
        </ul>
        <div class="flex flex-wrap gap-3 mb-10">
          <a href="/get-shortlist/" class="btn-primary px-6 py-3">Get free shortlist →</a>
          <a href="/guides/buy-cape-town-property-foreigner/" class="btn-secondary px-6 py-3">Foreign buyer guide</a>
          <a href="/guides/" class="btn-secondary px-6 py-3">Browse guides</a>
        </div>
        <div class="grid grid-cols-3 gap-3 max-w-md">
          <div class="stat-pill">
            <strong>{publishedGuides.length}</strong>
            <span>Guides</span>
          </div>
          <div class="stat-pill">
            <strong>{publishedProjects.length}</strong>
            <span>Projects</span>
          </div>
          <div class="stat-pill">
            <strong>{publishedAreas.length}</strong>
            <span>Areas</span>
          </div>
        </div>
      </div>
      <div class="hero-visual min-h-[280px] md:min-h-[380px] relative">
        <img src={heroImage} alt="Cape Town skyline with Table Mountain" loading="eager" width="1400" height="560" />
        <div class="hero-visual__overlay" />
        <p class="hero-visual__caption">Table Mountain · Atlantic Seaboard</p>
      </div>
    </div>
  </section>

  <section class="border-b border-[var(--color-border-soft)] bg-[var(--color-brand)] text-white py-8">
    <div class="site-container grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-2xl md:text-3xl font-semibold">0%</p>
        <p class="text-sm opacity-85 mt-1">Foreign buyer surcharge</p>
      </div>
      <div>
        <p class="text-2xl md:text-3xl font-semibold">50%</p>
        <p class="text-sm opacity-85 mt-1">Typical non-resident bond cap</p>
      </div>
      <div>
        <p class="text-2xl md:text-3xl font-semibold">6–9%</p>
        <p class="text-sm opacity-85 mt-1">MODELED gross yields (prime)</p>
      </div>
      <div>
        <p class="text-2xl md:text-3xl font-semibold">$250K+</p>
        <p class="text-sm opacity-85 mt-1">Entry from (USD)</p>
      </div>
    </div>
  </section>

  <section class="section bg-[var(--color-surface)] border-y border-[var(--color-border-soft)]">
    <div class="site-container max-w-3xl">
      <h2 class="text-2xl mb-3">Start here — highest-intent guides</h2>
      <p class="text-[var(--color-muted)] mb-6">
        {publishedGuides.length} buyer guides, {publishedProjects.length} project reviews, and {publishedAreas.length} area reports — updated June 2026.
      </p>
      <ul class="space-y-3">
        <li><a href="/guides/buy-cape-town-property-foreigner/" class="link-arrow font-medium">Buying Cape Town property as a foreigner →</a></li>
        <li><a href="/guides/cape-town-property-investment-guide/" class="link-arrow font-medium">Cape Town property investment guide (pillar) →</a></li>
        <li><a href="/guides/short-term-rental-rules-cape-town/" class="link-arrow font-medium">Short-term rental rules — 4 layers before you Airbnb →</a></li>
        <li><a href="/guides/century-city-property-investment-guide/" class="link-arrow font-medium">Century City income play — 7.7% MODELED gross →</a></li>
        <li><a href="/areas/green-point-property-investment/" class="link-arrow font-medium">Green Point — 8% gross, V&A Waterfront edge →</a></li>
        <li><a href="/projects/" class="link-arrow font-medium">Project reviews (21 live) →</a></li>
      </ul>
    </div>
  </section>

  <section class="section bg-[var(--color-surface)] border-t border-[var(--color-border-soft)]">
    <div class="site-container max-w-xl">
      <h2 class="text-2xl mb-3">Get your Cape Town shortlist</h2>
      <p class="text-[var(--color-muted)] mb-2">Budget, target area, yield or lifestyle goal — we match vetted resale and off-plan options.</p>
      <p class="text-sm text-[var(--color-muted)] mb-8">Independent editorial · Licensed SA partner review · No spam · Reply within one business day</p>
      <LeadForm
        title="Request your shortlist"
        subtitle="Atlantic Seaboard · City Bowl · Winelands · Century City"
        context="Homepage shortlist"
      />
    </div>
  </section>
</BaseLayout>
