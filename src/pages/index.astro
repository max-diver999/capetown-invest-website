---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../data/site';
import { HOMEPAGE_HERO_IMAGE } from '../data/featured';
import { getCardImageUrl } from '../lib/cardImage';

const [guides, projects, areas] = await Promise.all([
  getCollection('guides'),
  getCollection('projects'),
  getCollection('areas'),
]);

const publishedGuides = guides.filter((g) => !g.data.noindex);
const publishedProjects = projects.filter((p) => !p.data.noindex);
const publishedAreas = areas.filter((a) => !a.data.noindex);

const heroImage = getCardImageUrl(HOMEPAGE_HERO_IMAGE, 'hero');
---
<BaseLayout
  title="Cape Town Invest — Independent Cape Town Property Research"
  description={SITE.description}
>
  <section class="border-b border-[var(--color-border-soft)] bg-[var(--color-surface)]">
    <div class="site-container py-14 md:py-20 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div>
        <span class="badge-pill mb-5">Independent research</span>
        <h1 class="text-3xl md:text-[2.35rem] mb-5 leading-tight">
          Understand Cape Town property before you buy
        </h1>
        <p class="text-base md:text-lg text-[var(--color-muted)] mb-8 max-w-xl">
          Atlantic Seaboard, City Bowl, and Southern Suburbs — foreign ownership rules, transfer costs, rental yields, and new development reviews for international buyers.
        </p>
        <div class="flex flex-wrap gap-3 mb-10">
          <a href="/guides/" class="btn-primary px-6 py-3">Browse guides</a>
          <a href="/projects/" class="btn-secondary px-6 py-3">Project reviews</a>
          <a href="/get-shortlist/" class="btn-secondary px-6 py-3">Free shortlist →</a>
        </div>
        <div class="grid grid-cols-3 gap-3 max-w-md">
          <div class="stat-pill">
            <strong>{publishedGuides.length}</strong>
            <span>Guides</span>
          </div>
          <div class="stat-pill">
            <strong>{publishedProjects.length}</strong>
            <span>Projects</span>
          </div>
          <div class="stat-pill">
            <strong>{publishedAreas.length}</strong>
            <span>Areas</span>
          </div>
        </div>
      </div>
      <div class="hero-visual min-h-[280px] md:min-h-[380px] relative">
        <img src={heroImage} alt="Cape Town skyline with Table Mountain" loading="eager" width="1400" height="560" />
        <div class="hero-visual__overlay" />
        <p class="hero-visual__caption">Table Mountain · Atlantic Seaboard</p>
      </div>
    </div>
  </section>

  <section class="border-b border-[var(--color-border-soft)] bg-[var(--color-brand)] text-white py-8">
    <div class="site-container grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-2xl md:text-3xl font-semibold">40%</p>
        <p class="text-sm opacity-85 mt-1">Foreign share of R10m+ deals</p>
      </div>
      <div>
        <p class="text-2xl md:text-3xl font-semibold">0%</p>
        <p class="text-sm opacity-85 mt-1">Foreign buyer surcharge (vs UK/SG)</p>
      </div>
      <div>
        <p class="text-2xl md:text-3xl font-semibold">6–9%</p>
        <p class="text-sm opacity-85 mt-1">Gross rental yields (prime)</p>
      </div>
      <div>
        <p class="text-2xl md:text-3xl font-semibold">$250K+</p>
        <p class="text-sm opacity-85 mt-1">Entry from (USD)</p>
      </div>
    </div>
  </section>

  <section class="section bg-[var(--color-surface)] border-y border-[var(--color-border-soft)]">
    <div class="site-container max-w-3xl">
      <h2 class="text-2xl mb-3">Launching now</h2>
      <p class="text-[var(--color-muted)] mb-6">
        We are publishing buyer guides, area research, and project reviews for foreign investors. First batch covers ownership rules, transfer costs, rental yields, and Atlantic Seaboard micro-markets.
      </p>
      <ul class="list-disc pl-5 space-y-2 text-[var(--color-muted)]">
        <li>Cape Town property investment guide (pillar)</li>
        <li>Can foreigners buy property in South Africa</li>
        <li>How to buy property in Cape Town step by step</li>
        <li>Cost of buying property in Cape Town</li>
        <li>Cape Town rental yield guide</li>
        <li>Atlantic Seaboard investment guide</li>
      </ul>
      <p class="mt-6">
        <a href="/contact/" class="link-arrow">Contact the editorial team →</a>
      </p>
    </div>
  </section>

  <section class="section bg-[var(--color-surface)] border-t border-[var(--color-border-soft)]">
    <div class="site-container max-w-xl">
      <h2 class="text-2xl mb-3">Get a shortlist</h2>
      <p class="text-[var(--color-muted)] mb-8">Tell us budget and area preference — we match you with vetted Cape Town partners. No obligation.</p>
      <LeadForm context="Homepage shortlist" />
    </div>
  </section>
</BaseLayout>
